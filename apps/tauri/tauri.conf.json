{
  "build": {
    "beforeDevCommand": "node ./apps/tauri/scripts/sync-ios-composer-icon.mjs && pnpm --filter frontend dev:tauri",
    "beforeBuildCommand": "node ./apps/tauri/scripts/sync-ios-composer-icon.mjs && pnpm --filter frontend build:tauri",
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/ios/AppIcon-512@2x.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "2026 Teymz Inc.",
    "category": "public.app-category.finance",
    "createUpdaterArtifacts": "v1Compatible",
    "iOS": {
      "developmentTeam": "DYDJ2RNL5H",
      "infoPlist": "Info.ios.plist"
    },
    "macOS": {
      "bundleVersion": "20260301.1",
      "signingIdentity": "Apple Distribution: Teymz Inc (DYDJ2RNL5H)",
      "minimumSystemVersion": "10.13"
    }
  },
  "productName": "WhaleIt",
  "mainBinaryName": "WhaleIt",
  "version": "3.2.1",
  "identifier": "com.whaleit.app",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0RjI4MkRFOUYwRDM3N0QKUldSOU53MmYzb0x5WlBySmErU21wcjVHZFNtMW9zdGcyZTBBRWpVcHRDMkoyKzF1bkQ1VmdKbkYK",
      "endpoints": ["https://whaleit.app/releases/{{target}}/{{arch}}/{{current_version}}"],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "mobile": [
        { "host": "connect.whaleit.app", "pathPrefix": ["/deeplink"] },
        { "host": "connect-staging.whaleit.app", "pathPrefix": ["/deeplink"] }
      ],
      "desktop": {
        "schemes": ["whaleit"]
      },
      "schemes": ["whaleit"]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "dragDropEnabled": false,
        "fullscreen": false,
        "resizable": true,
        "theme": "Light",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "title": "WhaleIt",
        "width": 1440,
        "height": 960
      }
    ],
    "security": {
      "csp": null
    }
  }
}
