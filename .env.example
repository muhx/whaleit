# PostgreSQL connection string for the application database.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/whaleit

# Whaleit Connect - Required for cloud sync feature
CONNECT_AUTH_URL=https://your-auth-provider.example.com
CONNECT_AUTH_PUBLISHABLE_KEY=your-publishable-key
CONNECT_API_URL=https://api.whaleit.app
CONNECT_OAUTH_CALLBACK_URL=https://connect.whaleit.app/auth/callback
